  "cards": [
    {
      "dot": "emerald",
      "title": "Two-workflow design",
      "items": [
        "Harvest (weekly, Sun 12:00 UTC) refills queue.json from newly-starred repos",
        "Daily (06:00 AEST = 20:00 UTC) pops one entry and posts it",
        "queue.json + posted.json are the repo's own state — no external DB",
        "Stars API is paginated (per_page=100) with the auto GITHUB_TOKEN (public stars)"
      ]
    },
    {
      "dot": "rose",
      "title": "Auth boundary",
      "items": [
        "Only 2 CF-Access headers (Client Id + Secret) — no FlareMo app token",
        "Service Auth policy bypasses login; GitHub Actions IPs reach the Worker",
        "Secrets live in GH Actions env vars only — never logged, never posted as content",
        "Memo visibility = PROTECTED (signed-in instance users); body = {content, visibility}"
      ]
    },
    {
      "dot": "orange",
      "title": "Traceability (POC choices)",
      "items": [
        "posted.json is the dedupe log — harvest skips ids already posted or queued",
        "Empty queue → daily workflow exits 0 (no blank note posted)",
        "No per-run idempotency guard — manual re-runs may double-post (POC)",
        "Returned memo name (memos/{id}) is recorded in posted.json for audit"
      ]
    }
  ]
}